# ═══════════════════════════════════════════════════════════════════
# FPC Backend — Environment Variables
# Copy to .env and replace all "replace-me-*" values with real secrets.
# ═══════════════════════════════════════════════════════════════════

# ── Spring Profile ──────────────────────────────────────────────
# Which Spring profile to activate (dev, prod).
# Used by docker-compose to inject SPRING_PROFILES_ACTIVE at runtime.
SPRING_PROFILES_ACTIVE=dev

# ── GitHub Container Registry ───────────────────────────────────
# Your GitHub username or org that owns the GHCR image.
GHCR_REPO=hazarddev/fpc-back
# Tag of the Docker image to pull (set automatically by CI/CD workflows).
IMAGE_TAG=dev-latest

# ── PostgreSQL ──────────────────────────────────────────────────
# Shared credentials
DB_USERNAME=postgres

# Dev database — used by docker-compose.dev.yml
DB_URL_DEV=jdbc:postgresql://postgres:5432/fpc_db_dev
DB_PASSWORD_DEV=replace-me-dev-db-password

# Production database — used by docker-compose.prod.yml
DB_URL_PROD=jdbc:postgresql://postgres:5432/fpc_db
DB_PASSWORD_PROD=replace-me-prod-db-password

# ── JWT ─────────────────────────────────────────────────────────
# Token expiration times (milliseconds). 900000 = 15 min, 604800000 = 7 days.
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Dev JWT secret — generate with: openssl rand -base64 32
JWT_SECRET_DEV=replace-me-dev-jwt-secret

# Production JWT secret — generate with: openssl rand -base64 32
JWT_SECRET_PROD=replace-me-prod-jwt-secret

# ── VPS SSH (used by GitHub Actions workflows) ──────────────────
# Hostname or IP of the Hetzner VPS.
SSH_HOST=replace-me-vps-hostname
# SSH user for deployments (created by scripts/vps-setup.sh).
SSH_USER=deploy

# ── GHCR Token (used by GitHub Actions) ─────────────────────────
# Classic personal access token with write:packages scope.
# Set this as a GitHub Secret, NOT in .env on the VPS.
GHCR_TOKEN=replace-me-ghcr-token
